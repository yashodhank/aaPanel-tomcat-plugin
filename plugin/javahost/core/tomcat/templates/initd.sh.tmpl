#!/bin/bash
### BEGIN INIT INFO
# Provides:          javahost-@@app@@
# Required-Start:    $network $local_fs
# Required-Stop:     $network $local_fs
# Default-Start:     2 3 4 5
# Default-Stop:      0 1 6
# Short-Description: JavaHost Tomcat instance @@app@@
### END INIT INFO
# Rendered by JavaHost — fallback for hosts without systemd. Single source of
# truth for env is the setenv.sh inside CATALINA_BASE/bin.
export JAVA_HOME="@@java_home@@"
export CATALINA_HOME="@@catalina_home@@"
export CATALINA_BASE="@@catalina_base@@"
export CATALINA_PID="@@catalina_base@@/temp/tomcat.pid"
RUNAS="@@user@@"

# Use runuser (not the aaPanel-jailed `su`) to drop privileges.
run() { runuser -u "$RUNAS" -- bash -c "$1"; }
case "$1" in
  start)   run "$CATALINA_HOME/bin/catalina.sh start" ;;
  stop)    run "$CATALINA_HOME/bin/catalina.sh stop" ;;
  restart) run "$CATALINA_HOME/bin/catalina.sh stop"; sleep 2; run "$CATALINA_HOME/bin/catalina.sh start" ;;
  status)  [ -f "$CATALINA_PID" ] && kill -0 "$(cat "$CATALINA_PID")" 2>/dev/null && echo running || { echo stopped; exit 3; } ;;
  *)       echo "Usage: $0 {start|stop|restart|status}"; exit 1 ;;
esac
