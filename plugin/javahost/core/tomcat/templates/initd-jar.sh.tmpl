#!/bin/bash
### BEGIN INIT INFO
# Provides:          javahost-@@app@@
# Required-Start:    $network $local_fs
# Required-Stop:     $network $local_fs
# Default-Start:     2 3 4 5
# Default-Stop:      0 1 6
# Short-Description: JavaHost executable-JAR app @@app@@
### END INIT INFO
# Rendered by JavaHost — init.d fallback for executable-JAR apps on hosts
# without systemd. Single env source: @@app_dir@@/bin/app.env.
export JAVA_HOME="@@java_home@@"
export SERVER_PORT="@@port@@"
APP_DIR="@@app_dir@@"
PIDFILE="$APP_DIR/app.pid"
RUNAS="@@user@@"
JAR="$APP_DIR/app.jar"
JAVA_OPTS="@@java_opts@@"

start() {
  [ -f "$APP_DIR/bin/app.env" ] && . "$APP_DIR/bin/app.env"
  su -s /bin/bash -c "cd '$APP_DIR' && exec '$JAVA_HOME/bin/java' $JAVA_OPTS -jar '$JAR' >> '$APP_DIR/logs/app.out' 2>&1 & echo \$! > '$PIDFILE'" "$RUNAS"
}
case "$1" in
  start)   start ;;
  stop)    [ -f "$PIDFILE" ] && kill "$(cat "$PIDFILE")" 2>/dev/null; rm -f "$PIDFILE" ;;
  restart) "$0" stop; sleep 2; "$0" start ;;
  status)  [ -f "$PIDFILE" ] && kill -0 "$(cat "$PIDFILE")" 2>/dev/null && echo running || { echo stopped; exit 3; } ;;
  *)       echo "Usage: $0 {start|stop|restart|status}"; exit 1 ;;
esac
